{
  "name": "donna",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered senior companion assistant",
  "scripts": {
    "start": "node --disable-warning=DEP0040 index.js",
    "dev": "node --disable-warning=DEP0040 --watch index.js",
    "install:apps": "npm ci --prefix apps/admin-v2 && npm ci --prefix apps/consumer && npm ci --prefix apps/observability && npm ci --prefix apps/mobile",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:admin": "playwright test --project=admin",
    "test:e2e:consumer": "playwright test --project=consumer",
    "test:e2e:observability": "playwright test --project=observability",
    "test:e2e:integration": "playwright test --config=playwright.integration.config.ts"
  },
  "dependencies": {
    "@clerk/express": "^1.7.64",
    "@growthbook/growthbook": "^1.3.1",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/node": "^9.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.16.0",
    "resend": "^6.9.2",
    "twilio": "^5.13.1",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.13",
    "@playwright/test": "^1.50.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "msw": "^2.0.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    }
  }
}
