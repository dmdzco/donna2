{
  "expo": {
    "name": "Donna Companion",
    "slug": "donna-caregiver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "donna",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFCF8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.donna.caregiver",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID for quick sign-in",
        "NSCameraUsageDescription": "Donna uses the camera to let you set a profile photo",
        "NSPhotoLibraryUsageDescription": "Donna uses your photo library to let you set a profile photo"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FDFCF8"
      },
      "package": "com.donna.caregiver"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-font",
      "expo-splash-screen",
      "expo-system-ui",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aa482a04-3f14-4373-a654-42e51f1bd7b0"
      }
    },
    "owner": "dmdzco"
  }
}
