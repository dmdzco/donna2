# ============================================================================
# Node.js Admin API (repo root — serves frontend APIs + scheduler)
# ============================================================================
PORT=3001

# Database (shared by both backends)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/donna?sslmode=require

# Telnyx voice call initiation
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=...
TELNYX_CONNECTION_ID=...
TELNYX_PHONE_NUMBER=+1234567890

# Google AI (post-call analysis via Gemini Flash)
GOOGLE_API_KEY=your_gemini_api_key

# Anthropic voice LLM (Pipecat)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (embeddings + news search)
OPENAI_API_KEY=your_openai_key

# Auth
JWT_SECRET=your_jwt_secret
DONNA_API_KEY=your_api_key
DONNA_API_KEYS=pipecat:your_service_api_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Notifications
RESEND_API_KEY=re_...
NOTIFICATION_FROM_EMAIL=Donna <notifications@donna.care>

# Railway (set after deploy)
RAILWAY_PUBLIC_DOMAIN=

# ============================================================================
# Pipecat Voice Pipeline (pipecat/ directory — see pipecat/.env or Railway)
# ============================================================================
# Pipecat has its own env vars configured on Railway.
# See pipecat/.env.example for the full list.

# Mobile app env lives in apps/mobile/.env.example
