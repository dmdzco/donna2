{
  "expo": {
    "name": "Donna",
    "slug": "donna-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "donna",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.donna.mobile"
    },
    "android": {
      "package": "com.donna.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
